{
    "name": "alt-design/alt-redirect",
    "description": "Alt Redirect addon, add Redirects to your site",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "AltDesign\\AltRedirect\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AltDesign\\AltRedirect\\Tests\\": "tests"
        }
    },
    "require": {
        "php": "^8.1",
        "statamic/cms": "^6.0"
    },
    "extra": {
        "statamic": {
            "name": "Alt Redirect",
            "description": "Alt Redirect addon"
        },
        "laravel": {
            "providers": [
                "AltDesign\\AltRedirect\\ServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pixelfear/composer-dist-plugin": true,
            "pestphp/pest-plugin": true
        }
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1",
        "orchestra/testbench": "^11.1"
    }
}
